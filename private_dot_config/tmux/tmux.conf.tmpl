##################
## TMUX OPTIONS ##
##################
set-option -sa terminal-overrides ",xterm*:Tc"
set -gs extended-keys on
set -as terminal-features 'xterm*:extkeys'
set -g extended-keys-format csi-u

set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set-window-option -g automatic-rename off

set -g mouse on
set -g @yank_action 'copy-pipe'

set -g allow-passthrough on

run-shell "tmux set-option -g default-shell $(command -v zsh)"

#################
## KEYBINDINGS ##
#################
unbind C-b
set-option -g prefix C-a
bind C-a send-prefix

bind a run-shell "~/.local/bin/tmux-attach"

bind -n C-PPage previous-window
bind -n C-NPage next-window

# bind -n M-H resize-pane -L 2
# bind -n M-L resize-pane -R 2
# bind -n M-K resize-pane -U 2
# bind -n M-J resize-pane -D 2

bind  c  new-window      -c "#{pane_current_path}"
bind  %  split-window -h -c "#{pane_current_path}"
bind '"' split-window -v -c "#{pane_current_path}"

bind-key -n C-S-Left swap-window -t -1\; select-window -t -1
bind-key -n C-S-Right swap-window -t +1\; select-window -t +1

# go to the top/first pane and maximize it
bind Z select-pane -t 1 \; resize-pane -Z

bind r source-file ~/.config/tmux/tmux.conf \; display "Config reloaded!"

#############
## PLUGINS ##
#############
set -g @plugin 'tmuxpack/tpack'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-plugins/tmux-prefix-highlight'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'tmux-plugins/tmux-resurrect'

###########
## THEME ##
###########

# Messages
set-option -g mode-style "reverse"
set-option -g message-style "bg=default,fg=red"

# Center
set-option -g status-justify centre
set-option -g status-style "bg=default"

set-window-option -g window-status-current-format '#[bold]#[fg=red, bg=default]#[fg=black, bg=red] #I  #W #{?window_zoomed_flag,(ZOOMED),} #[fg=red, bg=default]'
set-window-option -g window-status-format ' #I #W '
set-window-option -g window-status-separator ' '
set-window-option -g window-status-style "bg=default"
set-window-option -g window-status-current-style "bg=default,fg=red"

# Left
set-option -g status-left '#{prefix_highlight}'

# highlights
set -g @prefix_highlight_show_copy_mode 'on'
set -g @prefix_highlight_copy_mode_attr 'fg=black,bg=yellow,bold'
set -g @prefix_highlight_show_sync_mode 'on'
set -g @prefix_highlight_sync_mode_attr 'fg=black,bg=red'
set -g @prefix_highlight_copy_prompt 'COPY'
set -g @prefix_highlight_sync_prompt 'SYNC'

# Right
set-option -g status-right '#[fg=green, bg=default]#[fg=black, bg=green] #S #[fg=green, bg=default]'

##########
## INIT ##
##########
run 'tpack init'

{{- if eq .chezmoi.os "darwin" }}
# RE-BIND ALL NAV KEYS FOR MACOS/CSI-U COMPATIBILITY
# We do this AFTER init to ensure we override the plugin's defaults

# 1. Define detection (local scope for safety)
is_vim="ps -o state= -o comm= -t '#{pane_tty}' | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|n?vim?x?)(diff)?$'"

# 2. Map all 4 directions explicitly
# These bindings work even when extended-keys/csi-u are active
bind-key -n 'C-h' if-shell "$is_vim" 'send-keys C-h' 'select-pane -L'
bind-key -n 'C-j' if-shell "$is_vim" 'send-keys C-j' 'select-pane -D'
bind-key -n 'C-k' if-shell "$is_vim" 'send-keys C-k' 'select-pane -U'
bind-key -n 'C-l' if-shell "$is_vim" 'send-keys C-l' 'select-pane -R'

# 3. Fix for Copy Mode navigation
bind-key -T copy-mode-vi 'C-h' select-pane -L
bind-key -T copy-mode-vi 'C-j' select-pane -D
bind-key -T copy-mode-vi 'C-k' select-pane -U
bind-key -T copy-mode-vi 'C-l' select-pane -R
{{- end }}
